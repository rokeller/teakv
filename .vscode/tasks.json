{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "--no-restore",
                "${workspaceFolder}/TeaSuite.KV.slnx",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Test",
            "command": "dotnet",
            "type": "process",
            "dependsOn": "cleanup-tests",
            "args": [
                "test",
                "${workspaceFolder}/TeaSuite.KV.slnx",
                "--collect:\"XPlat Code Coverage\"",
                "--no-build",
                "-r",
                "${workspaceFolder}/TestResults/Temp",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        // {
        //     "label": "publish",
        //     "command": "dotnet",
        //     "type": "process",
        //     "args": [
        //         "publish",
        //         "${workspaceFolder}/src/TeaSuite.KV/TeaSuite.KV.csproj",
        //         "/property:GenerateFullPaths=true",
        //         "/consoleloggerparameters:NoSummary"
        //     ],
        //     "problemMatcher": "$msCompile"
        // },
        // {
        //     "label": "Watch",
        //     "command": "dotnet",
        //     "type": "process",
        //     "args": [
        //         "watch",
        //         "run",
        //         "--project",
        //         "${workspaceFolder}/src/TeaSuite.KV/TeaSuite.KV.csproj"
        //     ],
        //     "problemMatcher": "$msCompile"
        // },
        {
            "label": "Cleanup-Tests",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "${workspaceFolder}/TestResults/Temp"
            ]
        }
    ]
}
